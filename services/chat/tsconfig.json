{
  "extends": "@packages/config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "exactOptionalPropertyTypes": true,

    "removeComments": true,
    "paths": {
      "@services/chat/*": ["./src/*"],
      "@packages/models/*": ["node_modules/@packages/models/src/*"],
      "@packages/prompts/*": ["node_modules/@packages/prompts/src/*"],
      "@services/expenses/*": ["node_modules/@services/expenses/src/*"],
      "@services/shared/*": ["node_modules/@services/shared/src/*"]
    }
  },
  "include": ["./src", "eslint.config.ts", "jest.config.ts"],
  "exclude": ["node_modules", "dist", ".turbo"]
}
