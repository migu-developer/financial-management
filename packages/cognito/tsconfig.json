{
  "extends": "@packages/config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@custom-message/*": ["./src/custom-message/*"],
      "@user-sync/*": ["./src/user-sync/*"],
      "@pre-signup/*": ["./src/pre-signup/*"],
      "@packages/models/*": ["node_modules/@packages/models/src/*"],
      "@services/shared/*": ["node_modules/@services/shared/src/*"],
      "@services/users/*": ["node_modules/@services/users/src/*"]
    }
  },
  "include": ["src", "eslint.config.ts"],
  "exclude": ["node_modules", "dist"]
}
