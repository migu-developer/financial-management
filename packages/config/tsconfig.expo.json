{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Expo (extends project base)",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-native",
    "lib": ["DOM", "ESNext"],
    "module": "preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "customConditions": ["react-native"],
    "noEmit": true,
    "target": "ESNext",
    "declaration": false,
    "declarationMap": false
  },
  "exclude": [
    "node_modules",
    "**/node_modules",
    ".turbo",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "android",
    "ios"
  ]
}
