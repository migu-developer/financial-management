{
  "extends": "@packages/config/tsconfig.expo.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@features/ui": ["./src/index.ts"],
      "@features/ui/components/*": ["./src/components/*"],
      "@features/ui/utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src", "nativewind-env.d.ts"],
  "exclude": ["node_modules", ".turbo"]
}
