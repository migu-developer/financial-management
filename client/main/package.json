{
  "name": "@client/main",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "Financial Management app",
  "scripts": {
    "start": "expo start",
    "dev": "pnpm start",
    "reset-project": "tsx ./scripts/reset-project.ts",
    "fix-font-paths": "tsx ./scripts/fix-font-paths.ts",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "postbuild:web": "tsx ./scripts/fix-font-paths.ts",
    "build": "pnpm build:web && pnpm postbuild:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@expo/vector-icons": "catalog:",
    "@features/auth": "workspace:*",
    "@features/dashboard": "workspace:*",
    "@features/landing": "workspace:*",
    "@features/ui": "workspace:*",
    "@packages/i18n": "workspace:*",
    "@packages/models": "workspace:*",
    "@packages/utils": "workspace:*",
    "@react-navigation/bottom-tabs": "catalog:",
    "@react-navigation/elements": "catalog:",
    "@react-navigation/native": "catalog:",
    "expo": "catalog:",
    "expo-auth-session": "catalog:",
    "expo-constants": "catalog:",
    "expo-font": "catalog:",
    "expo-haptics": "catalog:",
    "expo-image": "catalog:",
    "expo-linear-gradient": "catalog:",
    "expo-linking": "catalog:",
    "expo-router": "catalog:",
    "expo-secure-store": "catalog:",
    "expo-splash-screen": "catalog:",
    "expo-status-bar": "catalog:",
    "expo-symbols": "catalog:",
    "expo-system-ui": "catalog:",
    "expo-web-browser": "catalog:",
    "nativewind": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "catalog:",
    "react-native-gifted-charts": "catalog:",
    "react-native-gesture-handler": "catalog:",
    "react-native-reanimated": "catalog:",
    "react-native-safe-area-context": "catalog:",
    "react-native-screens": "catalog:",
    "react-native-web": "catalog:",
    "react-native-worklets": "catalog:"
  },
  "devDependencies": {
    "@packages/config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "eslint": "^9.39.4",
    "eslint-config-expo": "catalog:",
    "jest": "~29.7.0",
    "jiti": "^2.6.1",
    "react-native-css-interop": "^0.2.3",
    "tailwindcss": "^3.4.19",
    "ts-jest": "catalog:",
    "ts-node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "author": "Miguel Angel Gutierrez Maya"
}
