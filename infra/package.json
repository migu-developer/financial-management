{
  "name": "@infra",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "infra": "bin/infra.ts"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:sfn-local": "bash scripts/sfn-local-test.sh",
    "test:sfn-teststate": "tsx scripts/sfn-teststate.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-sfn": "catalog:",
    "@packages/config": "workspace:*",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "aws-cdk": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "jest": "catalog:",
    "ts-jest": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@packages/cognito": "workspace:*",
    "@packages/models": "workspace:*",
    "@packages/notifications": "workspace:*",
    "@packages/prompts": "workspace:*",
    "@services/chat": "workspace:*",
    "@services/currencies": "workspace:*",
    "@services/documents": "workspace:*",
    "@services/expenses": "workspace:*",
    "@services/shared": "workspace:*",
    "@services/users": "workspace:*",
    "aws-cdk-lib": "catalog:",
    "constructs": "catalog:"
  },
  "author": "Miguel Angel Gutierrez Maya",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24"
  }
