{
  "name": "financial-management",
  "author": "Miguel Angel Gutierrez Maya",
  "description": "Financial Management",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,css,scss,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,css,scss,md,yml,yaml}\"",
    "prepare": "husky",
    "email:dev": "turbo email:dev --filter=@packages/transactional",
    "email:build": "turbo email:build --filter=@packages/transactional",
    "email:start": "turbo email:start --filter=@packages/transactional",
    "email:export": "turbo email:export --filter=@packages/transactional",
    "email:upload": "turbo email:upload --filter=@packages/transactional",
    "supabase:start": "turbo supabase:start --filter=@packages/supabase",
    "supabase:stop": "turbo supabase:stop --filter=@packages/supabase",
    "supabase:status": "turbo supabase:status --filter=@packages/supabase",
    "supabase:reset": "turbo supabase:reset --filter=@packages/supabase",
    "infra:cdk": "cd infra && pnpm cdk",
    "migrations:migrate": "tsx --tsconfig packages/migrations/tsconfig.json packages/migrations/src/cli.ts migrate",
    "migrations:rollback": "tsx --tsconfig packages/migrations/tsconfig.json packages/migrations/src/cli.ts rollback",
    "migrations:status": "tsx --tsconfig packages/migrations/tsconfig.json packages/migrations/src/cli.ts status",
    "migrations:create-migration": "tsx --tsconfig packages/migrations/tsconfig.json packages/migrations/src/cli.ts create-migration",
    "migrations:export": "tsx --tsconfig packages/migrations/tsconfig.json packages/migrations/src/cli.ts export"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@packages/config": "workspace:*",
    "husky": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "ts-node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=24"
  }
}
