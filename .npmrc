# ─── Supply Chain Security ─────────────────────────────────────────────────────

# Delay installing newly published packages by 24 hours.
# Most supply chain attacks are detected within the first few hours.
minimum-release-age=1440

# Block installation if a package loses trust indicators
# (e.g., maintainer removes 2FA, provenance missing on previously signed pkg).
trust-policy=no-downgrade

# Only direct dependencies may use git repos or tarball URLs.
# Transitive dependencies must come from the registry.
block-exotic-subdeps=true

# ─── Build Script Controls ────────────────────────────────────────────────────

# Fail if unreviewed build scripts are found in dependencies.
# Forces explicit approval via onlyBuiltDependencies in pnpm-workspace.yaml.
strict-dep-builds=true

# ─── Integrity & Validation ───────────────────────────────────────────────────

# Verify package integrity before linking from content-addressable store.
verify-store-integrity=true

# Warn if dependencies are out of sync before running scripts.
verify-deps-before-run=warn
